<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ShuttleTrackerApp.Views.DriverDashboardPage">

    <ScrollView>
        <VerticalStackLayout Padding="20">

            <Entry x:Name="startEntry" Placeholder="Start Location"/>
            <Entry x:Name="endEntry" Placeholder="End Location"/>
            <Entry x:Name="priceEntry" Placeholder="Price"/>
            <Entry x:Name="seatsEntry" Placeholder="Seats"/>

            <Button Text="Create Trip" Clicked="CreateTrip_Clicked"/>
            <Button Text="Start Tracking" Clicked="StartTracking_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>