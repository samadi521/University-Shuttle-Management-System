<ContentPage   xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShuttleTrackerApp.Views.DriverDashboardPage">

    <VerticalStackLayout Padding="10" Spacing="10">

        <Entry x:Name="startEntry" Placeholder="Start Location (Chilaw)" />
        <Entry x:Name="endEntry" Placeholder="End Location (Colombo)" />

        <Entry x:Name="priceEntry" Placeholder="Price" Keyboard="Numeric" />
        <Entry x:Name="seatsEntry" Placeholder="Seats" Keyboard="Numeric" />

        <Button Text="Start Trip"
            Clicked="OnStartTripClicked"/>

        <Button Text="Start Countdown"
            Clicked="OnStartCountdownClicked"/>

        <Label x:Name="countdownLabel"
           Text="Countdown: 0s"/>
        <Button Text="Select Route on Map"
        Clicked="OnOpenMapClicked"/>

    </VerticalStackLayout>
</ContentPage>