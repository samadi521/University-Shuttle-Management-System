<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShuttleTrackerApp.Views.RegisterPage">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Entry x:Name="nameEntry" Placeholder="Name"/>
        <Entry x:Name="emailEntry" Placeholder="Email"/>
        <Entry x:Name="phoneEntry" Placeholder="Phone"/>
        <Entry x:Name="passwordEntry" Placeholder="Password" IsPassword="True"/>

        <Picker x:Name="rolePicker" Title="Select Role">
            <Picker.Items>
                <x:String>student</x:String>
                <x:String>driver</x:String>
            </Picker.Items>
        </Picker>

        <Button Text="Register" Clicked="OnRegisterClicked"/>

    </VerticalStackLayout>

</ContentPage>