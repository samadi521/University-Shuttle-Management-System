<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ShuttleTrackerApp.Views.BookingPage">

    <CollectionView x:Name="tripList">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border StrokeThickness="1" Padding="10" Margin="5">

                    <VerticalStackLayout>
                        <Label Text="{Binding start_location}" FontAttributes="Bold"/>
                        <Label Text="{Binding end_location}"/>
                        <Label Text="{Binding price}"/>
                        <Label Text="{Binding available_seats}"/>

                        <Button Text="Book Seat"
                                Clicked="BookTrip_Clicked"/>
                    </VerticalStackLayout>

                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
