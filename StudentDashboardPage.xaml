
    <ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShuttleTrackerApp.Views.StudentDashboardPage">
    <ScrollView>
        <VerticalStackLayout Padding="10">

        <maps:Map x:Name="map"
          HeightRequest="300" />
        <Label Text="🚌 Available Buses"
               FontSize="22"
               HorizontalOptions="Center" />

        <CollectionView x:Name="busList">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Padding="10" Margin="5" BorderColor="Gray">

                        <VerticalStackLayout>

                            <Label Text="{Binding BusId, StringFormat='Bus ID: {0}'}"/>
                            <Label Text="{Binding Price, StringFormat='Price: Rs {0}'}"/>
                            <Label Text="{Binding Seats, StringFormat='Seats: {0}'}"/>
                            <Label Text="{Binding Countdown, StringFormat='Starts in {0}s'}"/>
                            <Label Text="FULL"
                               TextColor="Red"
                                 IsVisible="{Binding Seats, Converter={StaticResource ZeroToBoolConverter}}" />

                            <HorizontalStackLayout>

                                <Button Text="Track"
                                        Clicked="OnDetailsClicked"/>

                                <Button Text="Book"
                                        Clicked="OnBookingClicked"/>

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>
    </ScrollView>
</ContentPage>